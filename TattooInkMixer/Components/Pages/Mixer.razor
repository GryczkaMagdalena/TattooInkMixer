@page "/"
@page "/mixer"
@rendermode InteractiveServer
@using TattooInkMixer.Services

<MudPaper Class="pa-4">
    <MudTabs Rounded="true" PanelClass="pa-4">
        <MudTabPanel Text="Find recipe from target color">
            <MudText Typo="Typo.h6" GutterBottom="true">Requested color</MudText>

            <div class="color-editor requested-color-editor">
                <label class="color-swatch" style="@GetColorPreviewStyle(TargetHex)">
                    <input type="color" value="@GetColorInputValue(TargetHex)" @oninput="@(e => UpdateTargetFromPicker(e.Value?.ToString()))" />
                </label>

                <MudTextField T="string"
                              Label="HEX"
                              Value="@TargetHex"
                              ValueChanged="UpdateTargetFromHex"
                              Immediate="true"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense" />

                <MudTextField T="string"
                              Label="RGB"
                              Value="@HexToRgbText(TargetHex)"
                              ValueChanged="UpdateTargetFromRgb"
                              Immediate="true"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense" />
            </div>

            <MudNumericField T="int" Label="Max inks to use" Variant="Variant.Outlined" Min="1" Max="20" Class="mt-4" @bind-Value="MaxInks" />

            <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Solve" Class="mt-4">Mix</MudButton>

            @if (!string.IsNullOrWhiteSpace(Error))
            {
                <MudAlert Severity="Severity.Error" Dense="true" Class="mt-3">@Error</MudAlert>
            }

            @if (Result is not null)
            {
                <MudText Typo="Typo.h6" Class="mt-4">Recipe</MudText>

                <MudTable Items="@GetRecipeRows()" Dense="true" Hover="true" Bordered="true" Striped="true" Class="mt-2">
                    <HeaderContent>
                        <MudTh>Color</MudTh>
                        <MudTh>Percentage</MudTh>
                        <MudTh>Drops (1.5 ml)</MudTh>
                        <MudTh>Drops (3 ml)</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd>@context.Name (@context.Hex)</MudTd>
                        <MudTd><b>@context.PercentageText</b></MudTd>
                        <MudTd>@context.DropsFor15Ml</MudTd>
                        <MudTd>@context.DropsFor3Ml</MudTd>
                    </RowTemplate>
                </MudTable>

                <MudDivider Class="my-4" />
                <MudText>
                    Predicted mix: <b>@Result.PredictedHex</b>
                </MudText>
                <div class="mt-2" style="@GetColorPreviewStyle(Result.PredictedHex)"></div>
                <MudText Class="mt-2" Style="@GetSimilarityTextStyle(Result.ErrorRmse)">Similarity: @GetSimilarityText(Result.ErrorRmse)</MudText>
            }
        </MudTabPanel>

        <MudTabPanel Text="Calculate result from my mix">
            @if (!OwnedInks.Any())
            {
                <MudAlert Severity="Severity.Info" Dense="true" Variant="Variant.Filled" Class="mt-2">
                    You do not have any owned inks yet. Add your colors in <MudLink Href="/color-table">Color Table</MudLink> first.
                </MudAlert>
            }
            else
            {
                @foreach (var row in MixRows)
                {
                    <MudGrid Class="mt-2">
                        <MudItem xs="12" md="7">
                            <MudText Typo="Typo.caption" Class="mb-1">Ink</MudText>
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                <select class="mud-input-slot mud-input-root mud-input mud-input-outlined mud-select-input" value="@GetMixInkSelectValue(row)" @onchange="@(e => UpdateMixInkFromInput(row, e.Value?.ToString()))">
                                    <option value="">Select ink...</option>
                                    @for (var i = 0; i < OwnedInks.Count; i++)
                                    {
                                        var ink = OwnedInks[i];
                                        <option value="@i">@ink.Name (@ink.Hex)</option>
                                    }
                                </select>
                                <div style="@GetColorPreviewStyle(GetSelectedInkHex(row))"></div>
                            </MudStack>
                        </MudItem>
                        <MudItem xs="9" md="4">
                            <MudNumericField T="double"
                                             Label="Percentage"
                                             Min="0"
                                             Max="100"
                                             Value="@row.Percentage"
                                             ValueChanged="@(value => UpdateMixPercentage(row, value))"
                                             Variant="Variant.Outlined"
                                             Margin="Margin.Dense" />
                        </MudItem>
                        <MudItem xs="3" md="1" Class="d-flex align-center justify-center">
                            <MudIconButton Icon="@Icons.Material.Filled.RemoveCircle"
                                           Color="Color.Error"
                                           Disabled="@(MixRows.Count == 1)"
                                           OnClick="() => RemoveMixRow(row)" />
                        </MudItem>
                    </MudGrid>
                }

                <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Add" Class="mt-2" OnClick="AddMixRow">Add color</MudButton>
                <MudText Typo="Typo.caption" Class="mt-2 d-block">Each ink can only be selected once. Duplicate ink selections are blocked.</MudText>

                @if (MyMixValidationErrors.Count > 0)
                {
                    <MudAlert Severity="Severity.Error" Dense="true" Class="mt-3">
                        <ul class="ma-0 pl-4">
                            @foreach (var validationError in MyMixValidationErrors)
                            {
                                <li>@validationError</li>
                            }
                        </ul>
                    </MudAlert>
                }

                <MudButton Color="Color.Primary"
                           Variant="Variant.Filled"
                           Class="mt-3"
                           Disabled="@(!CanCalculateMyMix)"
                           OnClick="CalculateMyMix">
                    Calculate result
                </MudButton>

                @if (!string.IsNullOrWhiteSpace(MyMixNormalizationMessage))
                {
                    <MudAlert Severity="Severity.Info" Dense="true" Class="mt-3">@MyMixNormalizationMessage</MudAlert>
                }

                @if (!string.IsNullOrWhiteSpace(MyMixError))
                {
                    <MudAlert Severity="Severity.Warning" Dense="true" Class="mt-3">@MyMixError</MudAlert>
                }

                @if (!string.IsNullOrWhiteSpace(MyMixPredictedHex))
                {
                    <MudDivider Class="my-4" />
                    <MudText Typo="Typo.h6">Result</MudText>
                    <MudText Class="mt-2">Predicted HEX: <b>@MyMixPredictedHex</b></MudText>
                    <div class="mt-2" style="@GetColorPreviewStyle(MyMixPredictedHex)"></div>
                    <MudText Class="mt-2">RGB: @MyMixRgbText</MudText>
                }
            }
        </MudTabPanel>
    </MudTabs>
</MudPaper>

@code {
    private string TargetHex = "#FF8800";
    private int MaxInks = 4;
    private string? Error;
    private InkMixResult? Result;

    private List<OwnedInkOption> OwnedInks = [];
    private List<MixInputRow> MixRows = [];
    private string? MyMixPredictedHex;
    private string? MyMixRgbText;
    private string? MyMixError;
    private string? MyMixNormalizationMessage;
    private List<string> MyMixValidationErrors = [];

    private bool CanCalculateMyMix => OwnedInks.Count > 0 && MyMixValidationErrors.Count == 0;

    [Inject] private ColorTableStore ColorTableStore { get; set; } = default!;

    protected override void OnInitialized()
    {
        ColorTableStore.EnsureInitialized();
        LoadOwnedInks();
    }

    private void LoadOwnedInks()
    {
        OwnedInks = ColorTableStore.Entries
            .Where(entry => string.Equals(entry.Category, ColorCategory.Standard, StringComparison.OrdinalIgnoreCase))
            .Select(entry => new OwnedInkOption(entry.Name, entry.Hex))
            .ToList();

        if (OwnedInks.Count > 0 && MixRows.Count == 0)
            MixRows.Add(new MixInputRow { InkIndex = 0, Percentage = 100 });

        ValidateMyMixInputs();
    }

    private static string GetColorPreviewStyle(string hex) => $"background:{hex}; width:48px; height:28px; border:1px solid #999; border-radius:4px;";

    private static int DropsPerMilliliter => 20;

    private const double SmallestVisiblePercentage = 0.005;

    private IEnumerable<RecipeRow> GetRecipeRows()
    {
        if (Result is null)
            return Enumerable.Empty<RecipeRow>();

        return GetSolveCandidates().Zip(Result.Weights)
            .Where(pair => (pair.Second * 100) >= SmallestVisiblePercentage)
            .Select(pair => new RecipeRow(
                pair.First.DisplayName,
                pair.First.Hex,
                $"{(pair.Second * 100):0.00}%",
                CalculateDrops(pair.Second, 1.5),
                CalculateDrops(pair.Second, 3.0)));
    }

    private IEnumerable<SolveInkCandidate> GetSolveCandidates()
    {
        var entries = ColorTableStore.Entries;
        var userInks = entries
            .Where(entry => string.Equals(entry.Category, ColorCategory.Standard, StringComparison.OrdinalIgnoreCase))
            .Select(entry => new SolveInkCandidate(entry.Name, entry.Hex));

        var marketInks = entries
            .Where(entry => string.Equals(entry.Category, ColorCategory.Company, StringComparison.OrdinalIgnoreCase))
            .Select(entry => new SolveInkCandidate($"{entry.Brand ?? string.Empty} - {entry.Name}", entry.Hex));

        return userInks.Concat(marketInks);
    }

    private static string GetSimilarityText(double rmse)
    {
        var similarity = Math.Clamp(1.0 - rmse, 0.0, 1.0);
        return $"{(similarity * 100):0.00}%";
    }

    private static string GetSimilarityTextStyle(double rmse)
    {
        var similarity = Math.Clamp(1.0 - rmse, 0.0, 1.0);
        if (similarity >= 0.95)
            return "color:#00C853;";

        if (similarity >= 0.90)
            return "color:#FB8C00;";

        return "color:#FF1744;";
    }

    private static int CalculateDrops(double weight, double cupSizeMl)
    {
        var totalDrops = cupSizeMl * DropsPerMilliliter;
        return (int)Math.Round(totalDrops * weight, MidpointRounding.AwayFromZero);
    }

    private static string GetColorInputValue(string hex)
    {
        try
        {
            _ = Rgb.FromHex(hex);
            return hex;
        }
        catch
        {
            return "#808080";
        }
    }

    private static string HexToRgbText(string hex)
    {
        try
        {
            var rgb = Rgb.FromHex(hex);
            return $"{rgb.R}, {rgb.G}, {rgb.B}";
        }
        catch
        {
            return string.Empty;
        }
    }

    private static string? RgbTextToHex(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
            return null;

        var parts = value.Split(',', StringSplitOptions.TrimEntries | StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length != 3)
            return null;

        if (!byte.TryParse(parts[0], out var r) || !byte.TryParse(parts[1], out var g) || !byte.TryParse(parts[2], out var b))
            return null;

        return $"#{r:X2}{g:X2}{b:X2}";
    }

    private void UpdateTargetFromPicker(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
            return;

        TargetHex = value.ToUpperInvariant();
        Result = null;
    }

    private void UpdateTargetFromHex(string? value)
    {
        TargetHex = string.IsNullOrWhiteSpace(value) ? string.Empty : value.Trim();
        Result = null;
    }

    private void UpdateTargetFromRgb(string? value)
    {
        var hex = RgbTextToHex(value);
        if (hex is null)
            return;

        TargetHex = hex;
        Result = null;
    }

    private void Solve()
    {
        Error = null;
        Result = null;

        try
        {
            _ = Rgb.FromHex(TargetHex);
            var solveCandidates = GetSolveCandidates().ToList();
            foreach (var ink in solveCandidates) _ = Rgb.FromHex(ink.Hex);

            var hexes = solveCandidates.Select(x => x.Hex).ToList();
            Result = InkMixSolver.SolveWithLimit(hexes, TargetHex, MaxInks);
        }
        catch (Exception ex)
        {
            Error = ex.Message;
        }
    }

    private static string GetMixInkSelectValue(MixInputRow row)
        => row.InkIndex?.ToString() ?? string.Empty;

    private string GetSelectedInkHex(MixInputRow row)
    {
        if (!row.InkIndex.HasValue || row.InkIndex.Value < 0 || row.InkIndex.Value >= OwnedInks.Count)
            return "#808080";

        return OwnedInks[row.InkIndex.Value].Hex;
    }

    private void UpdateMixInkFromInput(MixInputRow row, string? value)
    {
        if (!int.TryParse(value, out var selectedIndex))
        {
            row.InkIndex = null;
            HandleManualInputUpdated();
            return;
        }

        UpdateMixInk(row, selectedIndex);
    }

    private void AddMixRow()
    {
        MixRows.Add(new MixInputRow { InkIndex = null, Percentage = 0 });
        HandleManualInputUpdated();
    }

    private void RemoveMixRow(MixInputRow row)
    {
        MixRows.Remove(row);
        HandleManualInputUpdated();
    }

    private void UpdateMixInk(MixInputRow row, int? value)
    {
        row.InkIndex = value;
        HandleManualInputUpdated();
    }

    private void UpdateMixPercentage(MixInputRow row, double value)
    {
        row.Percentage = value;
        HandleManualInputUpdated();
    }

    private void HandleManualInputUpdated()
    {
        MyMixPredictedHex = null;
        MyMixRgbText = null;
        MyMixError = null;
        MyMixNormalizationMessage = null;

        ValidateMyMixInputs();
    }

    private void ValidateMyMixInputs()
    {
        MyMixValidationErrors = [];

        if (MixRows.Count == 0)
        {
            MyMixValidationErrors.Add("Add at least one row to calculate a mix.");
            return;
        }

        var selectedInks = new HashSet<int>();
        for (var i = 0; i < MixRows.Count; i++)
        {
            var row = MixRows[i];
            var rowLabel = $"Row {i + 1}";

            if (!row.InkIndex.HasValue || row.InkIndex.Value < 0 || row.InkIndex.Value >= OwnedInks.Count)
            {
                MyMixValidationErrors.Add($"{rowLabel}: select an ink.");
            }
            else if (!selectedInks.Add(row.InkIndex.Value))
            {
                MyMixValidationErrors.Add($"{rowLabel}: duplicate ink selected. Choose a different ink.");
            }

            if (row.Percentage < 0)
                MyMixValidationErrors.Add($"{rowLabel}: percentage must be greater than or equal to 0.");
        }

        var totalPercentage = MixRows.Sum(row => row.Percentage);
        if (totalPercentage <= 0)
            MyMixValidationErrors.Add("Total percentage must be greater than 0.");
    }

    private void CalculateMyMix()
    {
        MyMixError = null;
        MyMixPredictedHex = null;
        MyMixRgbText = null;
        MyMixNormalizationMessage = null;

        ValidateMyMixInputs();
        if (!CanCalculateMyMix)
            return;

        if (OwnedInks.Count == 0)
            return;

        try
        {
            var rowsToMix = MixRows
                .Where(row => row.Percentage > 0)
                .ToList();

            if (rowsToMix.Count == 0)
            {
                MyMixError = "Add at least one row with a percentage above 0.";
                return;
            }

            var percentageTotal = rowsToMix.Sum(row => row.Percentage);
            var densities = rowsToMix
                .Select(row => InkModel.ReflectanceToDensity(InkModel.ReflectanceFromHex(OwnedInks[row.InkIndex!.Value].Hex)))
                .ToList();

            var normalizedWeights = rowsToMix
                .Select(row => row.Percentage / percentageTotal)
                .ToArray();

            if (Math.Abs(percentageTotal - 100) > 0.0001)
                MyMixNormalizationMessage = $"Percentages normalized from {percentageTotal:0.##}% to 100%.";

            var mixedReflectance = InkModel.MixReflectanceFromDensities(densities, normalizedWeights);
            var mixedRgb = Srgb.FromLinear(mixedReflectance);

            MyMixPredictedHex = mixedRgb.ToHex();
            MyMixRgbText = $"{mixedRgb.R}, {mixedRgb.G}, {mixedRgb.B}";
        }
        catch (Exception ex)
        {
            MyMixError = ex.Message;
        }
    }

    private sealed record RecipeRow(string Name, string Hex, string PercentageText, int DropsFor15Ml, int DropsFor3Ml);
    private sealed record SolveInkCandidate(string DisplayName, string Hex);
    private sealed record OwnedInkOption(string Name, string Hex);

    private sealed class MixInputRow
    {
        public int? InkIndex { get; set; }
        public double Percentage { get; set; }
    }
}
